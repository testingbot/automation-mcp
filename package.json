{
  "name": "@testingbot/automation-mcp",
  "version": "0.1.3",
  "description": "MCP server that lets AI agents drive remote browsers and devices on TestingBot's grid.",
  "type": "module",
  "main": "dist/register.js",
  "types": "dist/register.d.ts",
  "exports": {
    ".": {
      "types": "./dist/register.d.ts",
      "import": "./dist/register.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "testingbot-automation-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/testingbot/automation-mcp.git"
  },
  "homepage": "https://github.com/testingbot/automation-mcp#readme",
  "bugs": {
    "url": "https://github.com/testingbot/automation-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "testingbot",
    "playwright",
    "browser-automation",
    "ai-agent",
    "remote-browser"
  ],
  "author": "TestingBot",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "npm run lint && npm run format:check && npm test && tsc",
    "start": "node dist/index.js",
    "dev": "NODE_ENV=development tsx watch --clear-screen=false src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --dir tests/integration --testTimeout=120000",
    "dev:rebuild": "bash scripts/dev.sh",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "appium-mcp": "^1.82.1",
    "dotenv": "^16.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "testingbot-api": "^1.1.0",
    "webdriver": "^9.27.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitest/coverage-v8": "^3.1.3",
    "eslint": "^9.25.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.3"
  }
}
